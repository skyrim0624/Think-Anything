{
  "manifest_version": 3,
  "name": "Think Anytime",
  "short_name": "Think",
  "version": "0.1.0",
  "description": "随时在 Chrome 阅读现场呼出 AI 思考、追问、查库，并沉淀到 Obsidian。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "commands",
    "contextMenus",
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "side-panel.html"
  },
  "action": {
    "default_title": "Think Anytime",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "open_inline": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "展开 Think Anytime Dock 并附加当前上下文"
    },
    "open_twyr": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "打开 Think Anytime 讨论面板"
    },
    "quick_capture": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "快速保存当前选区到 Think Anytime"
    },
    "toggle_toolbar": {
      "description": "开启或关闭本页 Think Anytime 选区工具条"
    }
  }
}
